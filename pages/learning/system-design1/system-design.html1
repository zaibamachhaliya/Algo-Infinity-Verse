<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>System Design Whiteboard | Algo Infinity Verse</title>
    <meta name="description" content="Interactive drag-and-drop architecture whiteboard to design scalable systems." />
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Poppins:wght@300;400;500;600;700&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- External Stylesheets -->
    <link rel="stylesheet" href="styles.css" />
    <link rel="stylesheet" href="system-design.css" />
</head>
<body>
    <nav class="navbar">
        <div class="nav-logo">
            <span class="logo-text">∞</span>
            <span class="logo-title">Algo Infinity Verse</span>
        </div>
        <ul class="nav-links" id="navLinks">
            <li class="nav-item"><a href="#" class="nav-link">Home</a></li>
            <li class="nav-item"><a href="#" class="nav-link active" style="color: var(--sd-primary);">System Design</a></li>
            <li class="nav-item"><a href="#" class="nav-link">Practice</a></li>
        </ul>
    </nav>

    <div class="sd-app-container">
        <!-- Sidebar Palette -->
        <aside class="sd-sidebar">
            <div class="sidebar-header">
                <i class="fas fa-server"></i> Components
            </div>
            <div class="palette-container" id="palette">
                <!-- Draggable Items -->
                <div class="palette-item" draggable="true" data-type="client" data-color="#3b82f6" data-icon="fa-laptop">
                    <i class="fas fa-laptop"></i> Client
                </div>
                <div class="palette-item" draggable="true" data-type="server" data-color="#10b981" data-icon="fa-server">
                    <i class="fas fa-server"></i> Web Server
                </div>
                <div class="palette-item" draggable="true" data-type="database" data-color="#f59e0b" data-icon="fa-database">
                    <i class="fas fa-database"></i> Database
                </div>
                <div class="palette-item" draggable="true" data-type="cache" data-color="#ec4899" data-icon="fa-bolt">
                    <i class="fas fa-bolt"></i> Cache (Redis)
                </div>
                <div class="palette-item" draggable="true" data-type="lb" data-color="#8b5cf6" data-icon="fa-network-wired">
                    <i class="fas fa-network-wired"></i> Load Balancer
                </div>
                <div class="palette-item" draggable="true" data-type="queue" data-color="#14b8a6" data-icon="fa-layer-group">
                    <i class="fas fa-layer-group"></i> Message Queue
                </div>
                <div class="palette-item" draggable="true" data-type="storage" data-color="#64748b" data-icon="fa-box">
                    <i class="fas fa-box"></i> Object Storage
                </div>
            </div>

            <div class="sidebar-footer">
                <button class="btn-tool btn-danger" id="btnClearBoard">
                    <i class="fas fa-trash-alt"></i> Clear Board
                </button>
            </div>
        </aside>

        <!-- Main Drafting Board -->
        <main class="sd-workspace-wrapper">
            <div class="workspace-toolbar">
                <div class="toolbar-title">
                    Architecture Draft <span>- Drag components and connect ports to build data flows.</span>
                </div>
                <div class="toolbar-actions">
                    <button class="btn-tool" id="btnHelp" title="How to use">
                        <i class="fas fa-question-circle"></i> Help
                    </button>
                </div>
            </div>
            
            <!-- The actual drop zone and drawing area -->
            <div class="sd-workspace" id="workspace">
                <!-- SVG Layer for connection lines -->
                <svg class="sd-connections-layer" id="connectionLayer">
                    <!-- Temporary line drawn while dragging -->
                    <path class="temp-connection hidden" id="tempLine" d="M0,0 L0,0"></path>
                    <!-- Permanent connections injected here -->
                </svg>
                
                <!-- Nodes will be injected here -->
                <div class="workspace-placeholder" id="workspacePlaceholder">
                    <i class="fas fa-project-diagram"></i>
                    <h2>System Design Whiteboard</h2>
                    <p>Drag components from the palette here to begin building your architecture.</p>
                </div>
            </div>
        </main>
    </div>

    <!-- Help Modal Overlay -->
    <div class="modal-overlay hidden" id="helpModal">
        <div class="modal-content">
            <h3><i class="fas fa-drafting-compass"></i> How to use the Whiteboard</h3>
            <ul class="help-list">
                <li><strong>Add Components:</strong> Click and drag items from the left sidebar onto the blueprint.</li>
                <li><strong>Move Nodes:</strong> Click and drag any node on the board to reposition it.</li>
                <li><strong>Connect Nodes:</strong> Click and drag from the small colored dots (ports) on the sides of a node, and drop the line onto another node's port.</li>
                <li><strong>Delete:</strong> Double-click a node to remove it from the board.</li>
            </ul>
            <button class="btn-primary" id="btnCloseHelp">Got it!</button>
        </div>
    </div>
    
    <!-- External Scripts -->
    <script src="script.js"></script>
    <script src="system-design.js"></script>
</body>
</html>
